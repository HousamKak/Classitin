{
  "expo": {
    "name": "Classitin",
    "slug": "classitin",
    "version": "2.0.0",
    "orientation": "default",
    "scheme": "classitin",
    "platforms": ["ios", "android"],
    "ios": {
      "bundleIdentifier": "com.classitin.mobile",
      "supportsTablet": true,
      "deploymentTarget": "15.0",
      "infoPlist": {
        "NSCameraUsageDescription": "Classitin needs camera access for video calls with your teacher.",
        "NSMicrophoneUsageDescription": "Classitin needs microphone access for voice communication during class sessions.",
        "UIBackgroundModes": ["voip", "audio"],
        "CFBundleAllowMixedLocalizations": true,
        "RTCAppGroupIdentifier": "group.com.classitin.mobile",
        "RTCScreenSharingExtension": "com.classitin.mobile.BroadcastExtension"
      }
    },
    "android": {
      "package": "com.classitin.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#4F46E5"
      },
      "permissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION"
      ]
    },
    "plugins": [
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Classitin needs camera access for video calls.",
          "microphonePermission": "Classitin needs microphone access for voice communication."
        }
      ],
      "./plugins/withBroadcastExtension"
    ]
  }
}
